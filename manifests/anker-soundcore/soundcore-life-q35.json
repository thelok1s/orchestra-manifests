  "_capabilities_source": "Composed 2026-07-08 from OpenSCQ30 (github.com/oppzippy/OpenSCQ30, soundcore/a3027.rs) + Orchestra's hardware-verified Space One Pro / Liberty 4 Pro templates (same soundcore_v1 framing). Over-ear ANC (A3027). OpenSCQ30: 3 ambient modes + NC sub-modes, EQ, wearing detection, single battery. ALL functions ship _verified:false: command bytes are OpenSCQ30-/cousin-derived, not tested on this exact model — opt in per control in the Devices tab and confirm before trusting. Only the ANC 'sound_mode' (settingId 1001) and the feature toggles inject natively; EQ/button/battery are catalog-only for now. IMPORTANT: the RFCOMM control UUID (…d6832e7b3027) is derived from the model code and is a BEST GUESS — the socket won't open if it's wrong (cf. Liberty 4 Pro, whose UUID uses 3954 though the model is A3957). Confirm the vendor service UUID from an sdp/btsnoop dump before relying on this device.",
  "functions": [
    {
      "id": "sound_mode",
      "type": "multitoggle",
      "title": "Noise control",
      "title_i18n": {
        "ru": "Управление шумом"
      },
      "capability": "sound_modes",
      "options": [
        {
          "id": "anc",
          "label": "Noise Cancelling",
          "icon": "anc",
          "label_i18n": {
            "ru": "Шумоподавление"
          }
        },
        {
          "id": "off",
          "label": "Off",
          "icon": "off",
          "label_i18n": {
            "ru": "Выкл."
          }
        },
        {
          "id": "transparency",
          "label": "Transparency",
          "icon": "transparency",
          "label_i18n": {
            "ru": "Прозрачность"
          }
        }
      ],
      "set": {
        "command": "0681",
        "payload_template": "{mode}",
        "option_values": {
          "anc": "00000000",
          "off": "02000000",
          "transparency": "01000000"
        }
      },
      "read": {
        "command": "0101",
        "response_command": "0101",
        "state_byte_index": null,
        "value_map": {
          "00": "anc",
          "02": "off",
          "01": "transparency"
        }
      },
      "inject": "auto",
      "ui": {
        "setting_id": 1001,
        "surfaces": [
          "device_details",
          "volume_panel"
        ]
      },
      "_verified": false,
      "_verified_note": "Sound-mode command 0681 + mode mapping from OpenSCQ30; the exact payload (esp. the noise-canceling sub-mode / adaptive bytes and the discrete off/transparency mapping) is UNVERIFIED on this model — opt in via the Devices tab and confirm on-device before flipping _verified:true."
    },
    {
      "id": "wearing_detection",
      "type": "toggle",
      "title": "In-ear detection (auto-pause)",
      "capability": "wearing_detection",
      "set": {
        "command": "0181",
        "payload_template": "{state}",
        "state_values": {
          "on": "01",
          "off": "00"
        }
      },
      "read": {
        "command": "0101",
        "response_command": "0101",
        "state_byte_index": null,
        "value_map": {}
      },
      "inject": "auto",
      "ui": {
        "setting_id": 2001,
        "surfaces": [
          "device_details"
        ]
      },
      "_verified": false
    },
    {
      "id": "battery",
      "type": "info",
      "title": "Battery",
      "capability": "single_battery",
      "read": {
        "command": "0103",
        "response_command": "0103",
        "state_byte_index": null
      },
      "inject": false,
      "ui": {
        "setting_id": 2040,
        "surfaces": []
      },
      "_verified": false
    }
  ]
