  "_capture_note": "All commands verified live 2026-07-06 via btsnoop HCI capture (btsnoop.pcapng). Phone: Pixel 8 Pro Max Ultra+ (MAC c8:17:ec:7b:33:5c). Headphone: OpenSwim Pro by Shokz (MAC a0:0c:e2:49:22:05, Company ID 0x0cac). Control channel: L2CAP over RFCOMM (PSM 0x0003), custom shokz_v1 protocol. Two packet formats: A (53 ff ... 2d) for persistent settings writes; B (53 ef ... 31) for immediate action commands.",
  "match": {
    "name_regex": "(?i)(OpenSwim Pro|Shokz.OpenSwim.Pro)",
    "service_uuids_any": [
      "00001101-0000-1000-8000-00805f9b34fb"
    ],
    "manufacturer_id": "0x0cac"
  },
  "channels": {
    "rfcomm-control": {
      "transport": "rfcomm",
      "uuid": "00001101-0000-1000-8000-00805f9b34fb",
      "secure": false,
      "protocol": {
        "framing": "shokz_v1",
        "_doc": "Two packet formats share the same RFCOMM channel. FORMAT A (persistent settings): host->device 53 ff [seq:1] 01 a5 5a [inner_len:2LE] 01 00 00 00 [data_size:4LE] 02 00 00 00 04 00 00 00 01 00 00 00 03 00 00 00 04 00 00 00 [cmd_id:4LE] 04 00 00 00 [value_size:4LE] [value:4LE] 00 00 00 00 2d. FORMAT B (immediate action): host->device 53 ef [seq:1] a5 5a [inner_len:2LE] 01 00 00 00 [data_size:4LE] 02 00 00 00 04 00 00 00 01 00 00 00 03 00 00 00 04 00 00 00 [cmd_id:4LE] 04 00 00 00 [value:4LE] 31. Device ACK for FORMAT A: 51 ff 01 02 2d. Sequence byte increments per session. All multi-byte fields are u32 LE.",
        "format_a_prefix": "53ff",
        "format_a_magic": "01a55a",
        "format_a_tail": "2d",
        "format_b_prefix": "53ef",
        "format_b_magic": "a55a",
        "format_b_tail": "31",
        "cmd_id_size": 4,
        "value_size": 4,
        "endian": "little"
      }
    },
    "avrcp": {
      "transport": "aacp",
      "_doc": "Standard AVRCP over L2CAP PSM 0x0017 (AVCTP). Used for standard media controls via AVRCP PassThrough. Orchestra does NOT drive this channel. The headphone also supports playback controls via shokz_v1 in MP3 mode.",
      "_verified": true,
      "_note": "Observed AVRCP PassThrough opcode 0x17 on CID 0x0076 in btsnoop capture."
    }
  },
  "default_channel": "rfcomm-control",
